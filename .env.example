# ============================================================
# URO-OMEGA Environment Variables
# ============================================================

# ------------------------------------------------------------
# Database runtime selection (required)
# ------------------------------------------------------------
# "pglite" = offline-only, all data in OPFS (default for local dev)
# "postgres" = server-side Postgres (for Vercel / multi-device sync)
DB_RUNTIME=pglite
PGLITE_DATA_DIR=.pglite/uro-omega

# ------------------------------------------------------------
# Multi-device sync (optional)
# ------------------------------------------------------------
# Set this when you have a Postgres server for multi-device sync.
# Leave empty or unset for offline-only mode.
# Works with any Postgres provider (self-hosted, Docker, managed).
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# ------------------------------------------------------------
# App config
# ------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=URO-OMEGA
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ------------------------------------------------------------
# AI provider
# ------------------------------------------------------------
GROK_API_KEY=YOUR_KEY_HERE
GROK_API_URL=https://api.x.ai/v1/chat/completions
GROK_MODEL=grok-3

# ------------------------------------------------------------
# Single-user auth gate (required)
# ------------------------------------------------------------
# AUTH_SECRET signs the long-lived session cookie. MUST be a long random
# string (>= 32 chars recommended). Rotate it to force a global re-login.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=change-me-to-a-long-random-string

# Password verification. Preferred: STARSHIP_PASSWORD_HASH (PBKDF2).
# Generate with: node scripts/hash-password.mjs '<your-password>'
STARSHIP_PASSWORD_HASH=
# Plaintext fallback — used ONLY when STARSHIP_PASSWORD_HASH is empty.
APP_PASSWORD=

# ------------------------------------------------------------
# Starship media reader (Phase 1 — opt-in)
# ------------------------------------------------------------
# When set to "1", the library-v2 Reader detects image / figure / table
# references inside NOTE prose (e.g. "Figure 164.4", "تصویر ۲") and
# renders them as inline anchors that open a lightbox. Until the
# image importer ships, the lightbox shows a graceful "Image not
# imported yet" fallback. Set "0" or leave blank to keep the Reader
# unchanged. Per-device override: localStorage['starship-media-reader-override'].
NEXT_PUBLIC_STARSHIP_MEDIA_READER=0
