{
  "name": "starship",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:web": "npm run dev --prefix uro-killer/apps/web",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:web\"",
    "build": "next build",
    "build:web": "npm --prefix uro-killer/apps/web run build",
    "start": "next start",
    "lint": "next lint",
    "deploy:check": "node scripts/verify-vercel-readiness.mjs",
    "local:check": "node scripts/verify-local-runtime.mjs",
    "dev:backend": "next dev --turbo",
    "db:import": "tsx --tsconfig tsconfig.json scripts/import-batch.ts",
    "db:import:mcq": "tsx --tsconfig tsconfig.json scripts/import-mcq.ts",
    "db:bootstrap:pglite": "tsx --tsconfig tsconfig.json scripts/bootstrap-pglite.ts",
    "db:reset:pglite": "node scripts/reset-pglite.mjs",
    "db:push": "drizzle-kit push",
    "db:push:remote": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons:pwa": "node scripts/generate-pwa-icons.mjs",
    "icons:verify": "node scripts/verify-pwa-icons.mjs",
    "postinstall": "node scripts/copy-pglite-assets.mjs && node scripts/bundle-migrations.mjs"
  },
