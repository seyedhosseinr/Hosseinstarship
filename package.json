{
  "name": "starship",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:web": "npm run dev --prefix uro-killer/apps/web",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:web\"",
    "build": "next build",
    "build:web": "npm --prefix uro-killer/apps/web run build",
    "start": "next start",
    "lint": "next lint",
    "deploy:check": "node scripts/verify-vercel-readiness.mjs",
    "local:check": "node scripts/verify-local-runtime.mjs",
    "dev:backend": "next dev --turbo",
    "db:import": "tsx --tsconfig tsconfig.json scripts/import-batch.ts",
    "db:import:mcq": "tsx --tsconfig tsconfig.json scripts/import-mcq.ts",
    "db:bootstrap:pglite": "tsx --tsconfig tsconfig.json scripts/bootstrap-pglite.ts",
    "db:reset:pglite": "node scripts/reset-pglite.mjs",
    "db:push": "drizzle-kit push",
    "db:push:remote": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/copy-pglite-assets.mjs && node scripts/bundle-migrations.mjs"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@dnd-kit/core": "6.1.0",
    "@dnd-kit/utilities": "3.2.2",
    "@electric-sql/pglite": "^0.4.2",
    "@serwist/next": "^9.5.7",
    "@tanstack/react-query": "^5.75.0",
    "@types/pg": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-jalali": "^4.1.0-0",
    "dexie": "^4.0.11",
    "dompurify": "^3.3.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.1",
    "fabric": "^6.9.1",
    "fflate": "^0.8.2",
    "flexsearch": "^0.7.43",
    "framer-motion": "^12.35.1",
    "fuse.js": "^7.1.0",
    "html2canvas": "^1.4.1",
    "isomorphic-dompurify": "^2.22.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.487.0",
    "mermaid": "^11.14.0",
    "next": "^15.5.12",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^5.4.624",
    "pg": "^8.20.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.4",
    "serwist": "^9.5.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.2.0",
    "ts-fsrs": "^5.3.1",
    "uuid": "^13.0.0",
    "zod": "^3.24.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.3.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^2.1.9"
  }
}
