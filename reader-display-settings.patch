index 0000000..3e419c9
--- /dev/null
+++ b/src/components/library-v2/ReaderDisplaySettings.tsx
@@ -0,0 +1,228 @@
+"use client";
+
+import type { ReactNode } from "react";
+import { Check, Minus, Monitor, Moon, Plus, Sun, Type } from "lucide-react";
+import { useTheme } from "next-themes";
+import { cn } from "@/lib/utils";
+import type { ReaderSettings, ReaderTypeface } from "@/hooks/useReaderSettings";
+
+type ThemeChoice = "light" | "dark" | "system";
+
+type ReaderDisplaySettingsProps = {
+  settings: ReaderSettings;
+  onChange: (patch: Partial<ReaderSettings>) => void;
+  className?: string;
+};
+
+const THEME_OPTIONS: Array<{ value: ThemeChoice; label: string; icon: typeof Sun }> = [
+  { value: "light", label: "روشن", icon: Sun },
+  { value: "dark", label: "تاریک", icon: Moon },
+  { value: "system", label: "خودکار", icon: Monitor },
+];
+
+const TYPEFACE_OPTIONS: Array<{ value: ReaderTypeface; label: string; hint: string }> = [
+  { value: "vazirmatn", label: "Vazirmatn", hint: "پیشنهادی فارسی" },
+  { value: "system", label: "System", hint: "هماهنگ با دستگاه" },
+  { value: "open-dyslexic", label: "OpenDyslexic", hint: "با fallback امن" },
+];
+
+const LINE_WIDTH_STEPS = [540, 660, 720, 840, 900] as const;
+
+function stepValue(current: number, steps: readonly number[], direction: -1 | 1) {
+  const sorted = [...steps].sort((a, b) => a - b);
+  if (direction < 0) {
+    for (let i = sorted.length - 1; i >= 0; i -= 1) {
+      if (sorted[i] < current) return sorted[i];
+    }
+    return sorted[0];
+  }
+
+  for (const step of sorted) {
+    if (step > current) return step;
+  }
+  return sorted[sorted.length - 1];
+}
+
+function widthLabel(width: number) {
+  if (width <= 560) return "باریک";
+  if (width <= 680) return "نسبتاً باریک";
+  if (width <= 760) return "متوسط";
+  if (width <= 860) return "عریض";
+  return "خیلی عریض";
+}
+
+function typefaceLabel(typeface: ReaderTypeface) {
+  return TYPEFACE_OPTIONS.find((item) => item.value === typeface)?.label ?? "Vazirmatn";
+}
+
+function cycleTypeface(current: ReaderTypeface) {
+  const index = TYPEFACE_OPTIONS.findIndex((item) => item.value === current);
+  return TYPEFACE_OPTIONS[(index + 1) % TYPEFACE_OPTIONS.length].value;
+}
+
+function Stepper({
+  label,
+  value,
+  valueLabel,
+  icon,
+  minusLabel,
+  plusLabel,
+  canDecrease,
+  canIncrease,
+  onDecrease,
+  onIncrease,
+}: {
+  label: string;
+  value: string;
+  valueLabel?: string;
+  icon: ReactNode;
+  minusLabel: string;
+  plusLabel: string;
+  canDecrease: boolean;
+  canIncrease: boolean;
+  onDecrease: () => void;
+  onIncrease: () => void;
+}) {
+  return (
+    <div className="flex h-[55px] items-center gap-3 border-t border-lib-border/55 px-4 first:border-t-0">
+      <div className="flex h-9 w-9 shrink-0 items-center justify-center text-lib-text-muted">
+        {icon}
+      </div>
+      <div className="min-w-0 flex-1">
+        <div className="flex items-center gap-2 text-sm font-medium text-lib-text">
+          <span>{label}</span>
+          <span className="text-xs tabular-nums text-lib-text-muted">{value}</span>
+        </div>
+        {valueLabel && <div className="mt-0.5 text-[11px] text-lib-text-muted">{valueLabel}</div>}
+      </div>
+      <div className="flex overflow-hidden rounded-[10px] bg-lib-hover/80 ring-1 ring-lib-border/45">
+        <button
+          type="button"
+          onClick={onDecrease}
+          disabled={!canDecrease}
+          aria-label={minusLabel}
+          className="flex h-9 w-12 items-center justify-center text-lib-text-secondary transition hover:bg-lib-surface disabled:cursor-not-allowed disabled:opacity-35"
+        >
+          <Minus className="h-4 w-4" />
+        </button>
+        <div className="h-9 w-px bg-lib-border/55" />
+        <button
+          type="button"
+          onClick={onIncrease}
+          disabled={!canIncrease}
+          aria-label={plusLabel}
+          className="flex h-9 w-12 items-center justify-center text-lib-text-secondary transition hover:bg-lib-surface disabled:cursor-not-allowed disabled:opacity-35"
+        >
+          <Plus className="h-4 w-4" />
+        </button>
+      </div>
+    </div>
+  );
+}
+
+export function ReaderDisplaySettings({ settings, onChange, className }: ReaderDisplaySettingsProps) {
+  const { theme, setTheme } = useTheme();
+  const selectedTheme = (theme ?? "system") as ThemeChoice;
+
+  return (
+    <section
+      dir="rtl"
+      aria-label="تنظیمات خواندن"
+      className={cn(
