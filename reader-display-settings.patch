+"use client";
+
+import { useCallback, useEffect, useState } from "react";
+
+export type ReaderTypeface = "vazirmatn" | "system" | "open-dyslexic";
+
+export type ReaderSettings = {
+  fontSize: number; // px, 13–24
+  lineHeight: number; // multiplier, 1.4–2.2
+  maxWidth: number; // px, 540–900
+  typeface: ReaderTypeface;
+  showHighYield: boolean;
+  showKeyExam: boolean;
+  showMissedQuestions: boolean;
+};
+
+const STORAGE_KEY = "starship:reader-settings";
+
+const DEFAULTS: ReaderSettings = {
+  fontSize: 17,
+  lineHeight: 1.8,
+  maxWidth: 720,
+  typeface: "vazirmatn",
+  showHighYield: true,
+  showKeyExam: true,
+  showMissedQuestions: false,
+};
+
+const TYPEFACES = new Set<ReaderTypeface>(["vazirmatn", "system", "open-dyslexic"]);
+
+function clampNumber(value: unknown, min: number, max: number, fallback: number) {
+  if (typeof value !== "number" || !Number.isFinite(value)) return fallback;
+  return Math.min(max, Math.max(min, value));
+}
+
+function normalize(settings: Partial<ReaderSettings>): ReaderSettings {
+  return {
+    ...DEFAULTS,
+    ...settings,
+    fontSize: clampNumber(settings.fontSize, 13, 24, DEFAULTS.fontSize),
+    lineHeight: clampNumber(settings.lineHeight, 1.4, 2.2, DEFAULTS.lineHeight),
+    maxWidth: clampNumber(settings.maxWidth, 540, 900, DEFAULTS.maxWidth),
+    typeface: TYPEFACES.has(settings.typeface as ReaderTypeface)
+      ? (settings.typeface as ReaderTypeface)
+      : DEFAULTS.typeface,
+  };
+}
+
+export function getReaderTypefaceCss(typeface: ReaderTypeface) {
+  switch (typeface) {
+    case "system":
+      return `"SF Pro Text", "Segoe UI", Tahoma, var(--font-vazir), "Vazirmatn", sans-serif`;
+    case "open-dyslexic":
+      return `"OpenDyslexic", "OpenDyslexic3", "Atkinson Hyperlegible", var(--font-vazir), "Vazirmatn", Tahoma, sans-serif`;
+    case "vazirmatn":
+    default:
+      return `var(--font-vazir), "Vazirmatn", Tahoma, "SF Pro Text", -apple-system, sans-serif`;
+  }
+}
+
+function load(): ReaderSettings {
+  if (typeof window === "undefined") return DEFAULTS;
+  try {
+    const raw = localStorage.getItem(STORAGE_KEY);
+    if (!raw) return DEFAULTS;
+    return normalize(JSON.parse(raw));
+  } catch {
+    return DEFAULTS;
+  }
+}
+
+function save(settings: ReaderSettings) {
+  if (typeof window === "undefined") return;
+  try {
+    localStorage.setItem(STORAGE_KEY, JSON.stringify(settings));
+  } catch { /* ignore */ }
+}
+
+export function useReaderSettings() {
+  const [settings, setSettings] = useState<ReaderSettings>(DEFAULTS);
+
+  useEffect(() => {
+    setSettings(load());
+  }, []);
+
+  const update = useCallback((patch: Partial<ReaderSettings>) => {
+    setSettings((prev) => {
+      const next = normalize({ ...prev, ...patch });
+      save(next);
+      return next;
+    });
+  }, []);
+
+  const increaseFontSize = useCallback(() => {
+    update({ fontSize: Math.min(24, settings.fontSize + 1) });
+  }, [settings.fontSize, update]);
+
+  const decreaseFontSize = useCallback(() => {
+    update({ fontSize: Math.max(13, settings.fontSize - 1) });
+  }, [settings.fontSize, update]);
+
+  const resetDefaults = useCallback(() => {
+    setSettings(DEFAULTS);
+    save(DEFAULTS);
+  }, []);
+
+  return {
+    settings,
+    update,
+    increaseFontSize,
+    decreaseFontSize,
+    resetDefaults,
+  };
+}
