+                  ? "border-lib-accent bg-lib-accent-soft text-lib-accent shadow-[0_0_0_1px_color-mix(in_oklab,hsl(var(--primary))_36%,transparent)]"
+                  : "border-lib-border/60 text-lib-text-secondary hover:bg-lib-hover",
+              )}
+            >
+              <Icon className="h-7 w-7" />
+              <span>{option.label}</span>
+              {active && (
+                <span className="absolute right-2 top-2 flex h-4 w-4 items-center justify-center rounded-full bg-lib-accent text-lib-accent-fg">
+                  <Check className="h-3 w-3" />
+                </span>
+              )}
+            </button>
+          );
+        })}
+      </div>
+
+      <div className="px-1 pb-2 text-[13px] font-semibold text-lib-text-muted">سبک متن</div>
+      <div className="overflow-hidden rounded-[12px] border border-lib-border/60 bg-lib-bg/80">
+        <button
+          type="button"
+          onClick={() => onChange({ typeface: cycleTypeface(settings.typeface) })}
+          className="flex h-[58px] w-full items-center gap-3 px-4 text-right transition hover:bg-lib-hover"
+          aria-label="تغییر فونت خواندن"
+        >
+          <div className="flex h-9 w-9 shrink-0 items-center justify-center text-lib-text-muted">
+            <Type className="h-5 w-5" />
+          </div>
+          <div className="min-w-0 flex-1">
+            <div className="text-sm font-medium text-lib-text">فونت</div>
+            <div className="mt-0.5 text-[11px] text-lib-text-muted">
+              {TYPEFACE_OPTIONS.find((item) => item.value === settings.typeface)?.hint}
+            </div>
+          </div>
+          <div className="flex items-center gap-2 text-sm text-lib-text-secondary" dir="ltr">
+            <span>{typefaceLabel(settings.typeface)}</span>
+            <span className="text-lg text-lib-text-muted">›</span>
+          </div>
+        </button>
+
+        <Stepper
+          label="سایز متن"
+          value={`${settings.fontSize}px`}
+          icon={<span className="text-[23px] font-semibold leading-none">T</span>}
+          minusLabel="کوچک‌تر کردن متن"
+          plusLabel="بزرگ‌تر کردن متن"
+          canDecrease={settings.fontSize > 13}
+          canIncrease={settings.fontSize < 24}
+          onDecrease={() => onChange({ fontSize: settings.fontSize - 1 })}
+          onIncrease={() => onChange({ fontSize: settings.fontSize + 1 })}
+        />
+
+        <Stepper
+          label="فاصله خطوط"
+          value={settings.lineHeight.toFixed(1)}
+          icon={<span className="text-[22px] font-light leading-none">≡</span>}
+          minusLabel="کم کردن فاصله خطوط"
+          plusLabel="زیاد کردن فاصله خطوط"
+          canDecrease={settings.lineHeight > 1.4}
+          canIncrease={settings.lineHeight < 2.2}
+          onDecrease={() => onChange({ lineHeight: Number((settings.lineHeight - 0.1).toFixed(1)) })}
+          onIncrease={() => onChange({ lineHeight: Number((settings.lineHeight + 0.1).toFixed(1)) })}
+        />
+
+        <Stepper
+          label="عرض متن"
+          value={widthLabel(settings.maxWidth)}
+          valueLabel={`${settings.maxWidth}px`}
+          icon={<span className="text-[22px] leading-none">↔</span>}
+          minusLabel="کم کردن عرض متن"
+          plusLabel="زیاد کردن عرض متن"
+          canDecrease={settings.maxWidth > LINE_WIDTH_STEPS[0]}
+          canIncrease={settings.maxWidth < LINE_WIDTH_STEPS[LINE_WIDTH_STEPS.length - 1]}
+          onDecrease={() => onChange({ maxWidth: stepValue(settings.maxWidth, LINE_WIDTH_STEPS, -1) })}
+          onIncrease={() => onChange({ maxWidth: stepValue(settings.maxWidth, LINE_WIDTH_STEPS, 1) })}
+        />
+      </div>
+    </section>
+  );
+}
