  | "blue"
  | "green"
  | "pink"
  | "purple"
  | "orange";

export type ReaderHighlightColor = {
  id: ReaderHighlightColorId;
  label: string;
  semantic: string;
  storage: `#${string}`;
  swatch: string;
  background: string;
  underline: `#${string}`;
};

